# Supabase (required for API)
# Get both from: Supabase Dashboard -> your project -> Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# IMPORTANT: Use the "service_role" (secret) key, NOT the "anon" (publishable) key.
# Only service_role can bypass RLS so the backend can insert providers and requests.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-secret-key
# Optional: email notifications to admin
# NOTIFY_EMAIL=admin@nizamabadservices.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Optional: WhatsApp via Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# NOTIFY_WHATSAPP_TO=whatsapp:919876543210
